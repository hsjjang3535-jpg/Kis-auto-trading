# ── KIS API (한국투자증권) ──────────────────────────────────────
KIS_APP_KEY=여기에_앱키
KIS_APP_SECRET=여기에_앱시크릿
KIS_MODE=모의
KIS_ACCOUNT_NO=계좌번호(-없이, 모의는 50xxxxxxxx)
# 또는 분리 입력:
# KIS_CANO=50123456
# KIS_ACNT_PRDT_CD=01

# ── AI / 알림 ───────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
NAVER_CLIENT_ID=네이버_검색_API_ID
NAVER_CLIENT_SECRET=네이버_검색_API_SECRET
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=본인_chat_id

# ── 자금 관리 ───────────────────────────────────────────────────
MAX_TOTAL_AMOUNT=1000000
MAX_BUY_AMOUNT=500000
MAX_CLOSING_AMOUNT=500000
MAX_CLOSING_BUY=500000
CLOSING_BET_MAX_PER_SLOT=1
CLOSING_BET_MAX_POSITIONS=1
# Railway 상태 유실 시 지정 종가베팅 복구 (코드|종목명|매수일|복구만료일, 여러 개는 쉼표)
CLOSING_RECOVERY_POSITIONS=042700|한미반도체|2026-07-15|2026-07-29,004310|현대약품|2026-07-16|2026-07-30
# CLOSING_ACCOUNT_SYNC=false
# CLOSING_HOLD_EXCLUDE=
DYNAMIC_CAPITAL=true
BUY_RATIO=0.5

# ── 매매 규칙 ───────────────────────────────────────────────────
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=3.0
TRAILING_STOP_PCT=1.0
SELL_BLACKLIST=한미사이언스
MAX_WATCHLIST=15

# ── 스크리너 완화 (장중매매, 선택) ───────────────────────────────
MIN_CHANGE_RATE=-2.0
VOL_RATIO_MIN=1.2
W52_GAP_UPPER_MAX=10.0
W52_GAP_LOWER_MAX=25.0
# 상단매매 MA5 이격 상한 (기본 20, 이후 12~15로 조이기)
UPPER_MA5_GAP_MAX=20.0
# 장중 매수 직전 5분봉 확인 (양봉·상승·거래량)
ENTRY_5MIN_CONFIRM=true
ENTRY_5MIN_VOLUME_RATIO=1.0
UPPER_TAIL_MAX=0.35
CLOSING_BET_MIN_RATE=1.5
LOWER_RSI_MAX=50

# ── 장중매매 AI (false=기술조건만, true=Groq 2차 필터) ─────────────
ENABLE_INTRADAY_AI=false

# ── 낙폭반등 단타 (기본 OFF — true 시에만 동작, 모의투자에서는 자동 OFF) ──
ENABLE_CRASH_BOUNCE=false
CRASH_BOUNCE_ENTRY_START=09:10
CRASH_BOUNCE_ENTRY_END=10:30
CRASH_BOUNCE_TIME_EXIT=11:00
CRASH_BOUNCE_AFTERNOON_TIME_EXIT=14:20
CRASH_BOUNCE_AFTERNOON_VOLUME_RATIO=1.2
CRASH_BOUNCE_MIN_DROP=3.5
MAX_CRASH_BOUNCE_AMOUNT=500000
MAX_CRASH_BOUNCE_BUY=500000
CRASH_BOUNCE_MAX_POSITIONS=1
CRASH_BOUNCE_MAX_API_CALLS=20
CRASH_BOUNCE_TAKE_PROFIT=3.0
CRASH_BOUNCE_STOP_LOSS=2.0
CRASH_BOUNCE_MA_TOLERANCE=0.5
CRASH_BOUNCE_SCAN_TOP=20
CRASH_BOUNCE_MAX_CHART_CHECKS=5

# ── V자반등 단타 (기본 OFF — true 시에만 동작) ───────────────────
ENABLE_V_REVERSAL=false
V_REVERSAL_ENTRY_START=09:15
V_REVERSAL_ENTRY_END=10:30
V_REVERSAL_TIME_EXIT=14:20
V_REVERSAL_AFTERNOON_VOLUME_RATIO=1.2
V_REVERSAL_MIN_PREV_RATE=1.0
V_REVERSAL_MIN_DROP=2.0
V_REVERSAL_MAX_BELOW_PREV=1.0
MAX_V_REVERSAL_AMOUNT=500000
MAX_V_REVERSAL_BUY=500000
V_REVERSAL_MAX_POSITIONS=1
V_REVERSAL_MAX_API_CALLS=20
V_REVERSAL_TAKE_PROFIT=3.0
V_REVERSAL_TRAILING_STOP=1.0
V_REVERSAL_STOP_LOSS=2.0
V_REVERSAL_MA_TOLERANCE=0.5
V_REVERSAL_SCAN_TOP=30
V_REVERSAL_MAX_CHART_CHECKS=5

# ── 상한가 리바운드 (1단계: 알림만, 자동 매매 없음) ─────────────────
ENABLE_UL_REBOUND=false
UL_REBOUND_MONITOR_START=09:00
UL_REBOUND_MONITOR_END=15:30
UL_REBOUND_MIN_TRADING_VALUE=50000000000
UL_REBOUND_WINDOW_DAYS=7
UL_REBOUND_FORCE_SELL_DAY=4
UL_REBOUND_SCAN_TOP=30
UL_REBOUND_MAX_API_CALLS=25
UL_REBOUND_MAX_CHART_CHECKS=8
UL_REBOUND_MIN_HISTORY_DAYS=2
UL_REBOUND_LEVEL_TOLERANCE=0.5
UL_REBOUND_SIM_ENABLED=true
UL_REBOUND_SIM_AMOUNT=500000

# ── K1 종가베팅 (금요일 실전 / 월~목은 AI 종가베팅) ────────────────
ENABLE_K1_CLOSING=false
K1_CLOSING_ENTRY_START=14:20
K1_CLOSING_ENTRY_END=14:50
K1_MIN_TRADING_VALUE=50000000000
K1_MAX_BUY_DAYS_AFTER_UL=2
K1_FORCE_SELL_DAY=4
K1_SCAN_TOP=30
K1_MAX_API_CALLS=25
K1_MAX_CHART_CHECKS=8
K1_LEVEL_TOLERANCE=0.5
K1_SIM_ENABLED=true
K1_SIM_AMOUNT=500000

# ── K2 장중 (시뮬만 — 실전 주문 없음) ────────────────────────────────
ENABLE_K2_SIM=false
K2_MONITOR_START=09:10
K2_MONITOR_END=14:45
K2_MIN_TRADING_VALUE=50000000000
K2_MAX_DAYS_FROM_HIGH=4
K2_FORCE_SELL_DAY=4
K2_SCAN_TOP=20
K2_MAX_API_CALLS=20
K2_MAX_CHART_CHECKS=5
K2_MAX_WATCH=5
K2_LEVEL_TOLERANCE=0.5
K2_SIM_AMOUNT=500000

# ── K1플러스 (시뮬만 — 세력봉 당일, 실전 주문 없음) ─────────────
ENABLE_K1_PLUS_SIM=false
K1_PLUS_ENTRY_START=14:20
K1_PLUS_ENTRY_END=14:50
K1_PLUS_MONITOR_START=09:10
K1_PLUS_MONITOR_END=14:50
K1_PLUS_MIN_TRADING_VALUE=50000000000
