K1_PLUS_MAX_CHART_CHECKS=5
K1_PLUS_MAX_WATCH=5
K1_PLUS_LEVEL_TOLERANCE=0.5
K1_PLUS_SIM_AMOUNT=500000
K1_PLUS_REQUIRE_NEW_HIGH=true

# ── K2플러스 (시뮬만 — 세력봉 D1~D4 K2훼손, 실전 주문 없음) ─────
ENABLE_K2_PLUS_SIM=false
K2_PLUS_MONITOR_START=09:10
K2_PLUS_MONITOR_END=14:45
K2_PLUS_MIN_TRADING_VALUE=50000000000
K2_PLUS_MIN_DAY_RATE=5.0
K2_PLUS_MAX_DAYS_FROM_HIGH=4
K2_PLUS_FORCE_SELL_DAY=4
K2_PLUS_SCAN_TOP=20
