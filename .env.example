K2_PLUS_MAX_CHART_CHECKS=5
K2_PLUS_MAX_WATCH=5
K2_PLUS_LEVEL_TOLERANCE=0.5
K2_PLUS_SIM_AMOUNT=500000
K2_PLUS_REQUIRE_NEW_HIGH=true

# ── API 서버 (telegram-gemini-bot 연동용, 선택) ─────────────────
API_SECRET=임의_비밀문자열
PORT=8080
