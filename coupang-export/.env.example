# ── 쿠팡파트너스 Open API (partners.coupang.com → 도구 → Open API) ──
COUPANG_ACCESS_KEY=발급받은_ACCESS_KEY
COUPANG_SECRET_KEY=발급받은_SECRET_KEY
# 채널 ID (subId) — 미등록 채널 사용 시 정산에서 제외될 수 있음
COUPANG_SUB_ID=my-blog

# ── AI 콘텐츠 생성 (둘 중 하나 이상) ─────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OpenAI 미설정 시 Groq 사용
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── 워드프레스 자동 포스팅 (선택) ─────────────────────────────────
WP_SITE_URL=https://your-blog.com
WP_USERNAME=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
WP_POST_STATUS=draft
# draft | publish

# ── 파이프라인 설정 ───────────────────────────────────────────────
KEYWORDS_FILE=keywords.txt
PRODUCTS_PER_KEYWORD=3
MIN_PRODUCT_PRICE=5000
API_CALL_DELAY_SEC=1.5
DATA_DIR=data
DB_PATH=data/coupang.db
